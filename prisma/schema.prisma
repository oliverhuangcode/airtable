// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

generator zod {
    provider = "prisma-zod-generator"
    output   = "../generated/zod"
}

datasource db {
    provider = "postgresql"
}

// ─── NextAuth models ──────────────────────────────────────────────────────────
// Required by @auth/prisma-adapter — do not modify field names

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── App models ───────────────────────────────────────────────────────────────
//
//  User → Base → Table → Field   (column definitions)
//                      → Record  (row data stored as JSON blob)
//                      → View    (saved filter/sort/hidden config)
//
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?   // nullable — NextAuth adapter requires this
  email         String?   @unique // nullable — NextAuth adapter requires this
  emailVerified DateTime? // required by NextAuth adapter
  image         String?   // required by NextAuth adapter
  accounts      Account[]
  sessions      Session[]

  // app relations
  bases         Base[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Base {
  id          String   @id @default(cuid())
  name        String
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tables      Table[]
}

model Table {
  id        String   @id @default(cuid())
  name      String
  baseId    String
  base      Base     @relation(fields: [baseId], references: [id], onDelete: Cascade)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  fields    Field[]
  records   Record[]
  views     View[]

  @@index([baseId, order])
}

enum FieldType {
  TEXT
  NUMBER
}

model Field {
  id        String    @id @default(cuid())
  name      String
  type      FieldType @default(TEXT)
  tableId   String
  table     Table     @relation(fields: [tableId], references: [id], onDelete: Cascade)
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([tableId, name])
  @@index([tableId, order])
}

model Record {
  id        String   @id @default(cuid())
  tableId   String
  table     Table    @relation(fields: [tableId], references: [id], onDelete: Cascade)
  order     Int      @default(0)

  // All cell values stored as a JSON blob keyed by fieldId
  // e.g. { "fieldId_abc": "Alice", "fieldId_xyz": 42 }
  data      Json     @default("{}") @db.JsonB

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tableId, order])
  @@index([data], type: Gin)
}

model View {
  id           String   @id @default(cuid())
  name         String
  tableId      String
  table        Table    @relation(fields: [tableId], references: [id], onDelete: Cascade)
  filters      Json     @default("[]")
  sorts        Json     @default("[]")
  hiddenFields Json     @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tableId])
}
